                        "value": "<script>\n(function() {\n  var utms = ['utm_source', 'utm_medium', 'utm_campaign', \n              'utm_content', 'utm_term'];\n  var utmData = {};\n  \n  utms.forEach(function(key) {\n    var val = localStorage.getItem('txfhc_' + key);\n    if (val) utmData[key] = val;\n  });\n\n  // Push to dataLayer (existing behavior — don't remove this)\n  window.dataLayer = window.dataLayer || [];\n  dataLayer.push({\n    'event': 'utm_restored',\n    'utm_source':   utmData.utm_source   || '(not set)',\n    'utm_medium':   utmData.utm_medium   || '(not set)',\n    'utm_campaign': utmData.utm_campaign || '(not set)',\n    'utm_content':  utmData.utm_content  || '(not set)',\n    'utm_term':     utmData.utm_term     || '(not set)'\n  });\n\n  // Write UTMs back into the page URL so other tools can see them\n  var hasUtms = Object.keys(utmData).length > 0;\n  if (hasUtms) {\n    var params = new URLSearchParams(window.location.search);\n    Object.keys(utmData).forEach(function(key) {\n      params.set(key, utmData[key]);\n    });\n    history.replaceState(null, '', window.location.pathname + '?' + params.toString());\n  }\n})();\n</script>"
