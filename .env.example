# Google Ads API Credentials
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# From Google Cloud Console → OAuth 2.0 Client
GOOGLE_ADS_CLIENT_ID=your_client_id_here
GOOGLE_ADS_CLIENT_SECRET=your_client_secret_here

# Run scripts/get_google_refresh_token.py to generate this
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here

# From Google Ads API Center (https://ads.google.com/aw/apicenter)
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here

# Your MCC (Manager) account ID — no dashes
GOOGLE_ADS_CUSTOMER_ID=4781259815
