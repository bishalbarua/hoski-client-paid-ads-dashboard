# Google Ads API Credentials
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# From Google Cloud Console → OAuth 2.0 Client
GOOGLE_ADS_CLIENT_ID=your_client_id_here
GOOGLE_ADS_CLIENT_SECRET=your_client_secret_here

# Run scripts/get_google_refresh_token.py to generate this
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here

# From Google Ads API Center (https://ads.google.com/aw/apicenter)
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here

# Your MCC (Manager) account ID — no dashes
GOOGLE_ADS_CUSTOMER_ID=4781259815

# Meta (Facebook) Ads API Credentials
# From Meta for Developers > Your App > Settings > Basic
META_APP_ID=your_app_id_here
META_APP_SECRET=your_app_secret_here

# Long-lived System User token from Meta Business Manager > System Users
META_ACCESS_TOKEN=your_long_lived_access_token_here

# Google Sheets Integration
# The spreadsheet ID from the sheet URL: docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SHEETS_ID=your_spreadsheet_id_here
# Path to service account JSON (default: sheets-credentials.json in project root)
# GOOGLE_SHEETS_CREDS_PATH=sheets-credentials.json
